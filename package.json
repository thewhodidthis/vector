{
  "name": "@thewhodidthis/vector",
  "version": "0.0.9",
  "description": "Helps with vector math",
  "keywords": [
    "vector",
    "math"
  ],
  "main": "index.js",
  "module": "index.es",
  "homepage": "https://github.com/thewhodidthis/vector#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/vector.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/vector/issues"
  },
  "directories": {
    "example": "example"
  },
  "config": {
    "remote": "thewhodidthis@zazie:www/example/vector/"
  },
  "scripts": {
    "test": "node test",
    "clear": "npm run clear:dist && npm run clear:logs",
    "clear:dist": "rm -rf dist/",
    "clear:logs": "rm -f *.log",
    "lint": "eslint index.es; exit 0",
    "lint:example": "eslint example/index.js; exit 0",
    "start": "npm run build && npm run build:min",
    "preexample": "npm start",
    "example": "npm run example:build && npm run example:serve",
    "example:push": "rsync -avruzLPC --exclude=.DS_Store ./example/ $npm_package_config_remote",
    "example:watch": "nodemon -w example/index.js -C -q -x 'npm run example:build'",
    "example:build": "rollup -f iife example/index.js | babel --presets=es2015 -o example/build.js",
    "example:serve": "php -S localhost:8000 -t example/",
    "build": "rollup -c",
    "build:min": "uglifyjs dist/vector.js -cm > dist/vector.min.js",
    "preversion": "npm start"
  },
  "engines": {
    "node": ">=4.2.4",
    "npm": ">=3.5.3"
  },
  "dependencies": {},
  "devDependencies": {
    "babel-cli": "^6.24.0",
    "babel-eslint": "latest",
    "babel-plugin-external-helpers": "latest",
    "babel-preset-es2015": "latest",
    "eslint": "latest",
    "eslint-config-airbnb-base": "latest",
    "eslint-plugin-import": "latest",
    "nodemon": "latest",
    "rollup": "latest",
    "rollup-plugin-babel": "latest",
    "tape": "latest",
    "uglify-js": "latest"
  },
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (https://www.thewhodidthis.com)",
  "license": "Unlicense"
}
