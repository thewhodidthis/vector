{
  "name": "@thewhodidthis/vector",
  "version": "0.0.0",
  "description": "Just another vector class",
  "keywords": [
    "vector",
    "math"
  ],
  "main": "index.js",
  "homepage": "https://github.com/thewhodidthis/vector#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/vector.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/vector/issues"
  },
  "config": {
    "jscsrc": ".jscsrc"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clear": "npm run clear:dist && npm run clear:logs",
    "clear:dist": "rm -rf dist/",
    "clear:logs": "rm -f *.log",
    "lint": "(jshint index.js & jscs index.js --reporter=inlinesingle) 2>&1 | tee lint-js.log",
    "postlint": "find lint-js.log -size 0 -print0 | xargs -0 rm",
    "prestart": "npm run build",
    "start": "npm run watch",
    "watch": "watchify index.js -s Vector -o ./dist/vector.js",
    "prebuild": "mkdir -p dist/",
    "build": "browserify index.js -s Vector -o ./dist/vector.js",
    "build:min": "browserify index.js -s Vector | uglifyjs -o ./dist/vector.min.js",
    "postbuild": "npm run build:min",
    "preversion": "npm run clear:logs"
  },
  "engines": {
    "node": ">=4.2.4",
    "npm": ">=3.5.3"
  },
  "dependencies": {},
  "devDependencies": {
    "jscs": "latest",
    "jshint": "latest",
    "uglify-js": "latest",
    "browserify": "latest",
    "watchify": "latest"
  },
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (https://www.thewhodidthis.com)",
  "license": "Unlicense"
}
